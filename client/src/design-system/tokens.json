    "primitive": {
      "$description": "Raw color values — never reference directly in components",
      "cyan": {
        "50":  { "$value": "#e0fcff", "$type": "color" },
        "100": { "$value": "#b3f6ff", "$type": "color" },
        "200": { "$value": "#80efff", "$type": "color" },
        "300": { "$value": "#4de8ff", "$type": "color" },
        "400": { "$value": "#1ae1ff", "$type": "color" },
        "500": { "$value": "#00f5ff", "$type": "color", "$description": "Primary brand cyan" },
        "600": { "$value": "#00CED1", "$type": "color" },
        "700": { "$value": "#00A3A6", "$type": "color" },
        "800": { "$value": "#00787A", "$type": "color" },
        "900": { "$value": "#004D4F", "$type": "color" }
      },
      "green": {
        "50":  { "$value": "#e0fff0", "$type": "color" },
        "100": { "$value": "#b3ffdb", "$type": "color" },
        "200": { "$value": "#80ffc3", "$type": "color" },
        "300": { "$value": "#4dffab", "$type": "color" },
        "400": { "$value": "#1aff94", "$type": "color" },
        "500": { "$value": "#00ff94", "$type": "color", "$description": "Success green" },
        "600": { "$value": "#20d866", "$type": "color" },
        "700": { "$value": "#00b368", "$type": "color" },
        "800": { "$value": "#00804a", "$type": "color" },
        "900": { "$value": "#004d2d", "$type": "color" }
      },
      "magenta": {
        "50":  { "$value": "#ffe0fb", "$type": "color" },
        "100": { "$value": "#ffb3f5", "$type": "color" },
        "200": { "$value": "#ff80ee", "$type": "color" },
        "300": { "$value": "#ff4de7", "$type": "color" },
        "400": { "$value": "#FF00E5", "$type": "color", "$description": "Truth circle" },
        "500": { "$value": "#b600ff", "$type": "color", "$description": "Accent magenta" },
        "600": { "$value": "#9200cc", "$type": "color" },
        "700": { "$value": "#6e0099", "$type": "color" },
        "800": { "$value": "#4a0066", "$type": "color" },
        "900": { "$value": "#260033", "$type": "color" }
      },
      "gold": {
        "50":  { "$value": "#fff8e0", "$type": "color" },
        "100": { "$value": "#ffeeb3", "$type": "color" },
        "200": { "$value": "#ffe480", "$type": "color" },
        "300": { "$value": "#ffda4d", "$type": "color" },
        "400": { "$value": "#ffd166", "$type": "color", "$description": "Warning gold" },
        "500": { "$value": "#ffc233", "$type": "color" },
        "600": { "$value": "#cc9b29", "$type": "color" },
        "700": { "$value": "#99741f", "$type": "color" },
        "800": { "$value": "#664d14", "$type": "color" },
        "900": { "$value": "#33270a", "$type": "color" }
      },
      "red": {
        "50":  { "$value": "#ffe8ea", "$type": "color" },
        "100": { "$value": "#ffc5c9", "$type": "color" },
        "200": { "$value": "#ff9da4", "$type": "color" },
        "300": { "$value": "#ff8787", "$type": "color" },
        "400": { "$value": "#ff6b6b", "$type": "color" },
        "500": { "$value": "#ff5f6d", "$type": "color", "$description": "Error red" },
        "600": { "$value": "#ff4d4d", "$type": "color" },
        "700": { "$value": "#cc3d3d", "$type": "color" },
        "800": { "$value": "#992e2e", "$type": "color" },
        "900": { "$value": "#661f1f", "$type": "color" }
      },
      "neutral": {
        "0":   { "$value": "#ffffff", "$type": "color" },
        "50":  { "$value": "#f0f4ff", "$type": "color", "$description": "Primary text" },
        "100": { "$value": "#c8d2f0", "$type": "color" },
        "200": { "$value": "#a0aad0", "$type": "color" },
        "300": { "$value": "#7882b0", "$type": "color" },
        "400": { "$value": "#505a90", "$type": "color" },
        "500": { "$value": "#383f6e", "$type": "color" },
        "600": { "$value": "#282e52", "$type": "color" },
        "700": { "$value": "#1a1e3a", "$type": "color" },
