{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "Dawayir Design System",
    "version": "1.0.0",
    "description": "Design tokens for the Dawayir Live Agent — a real-time Arabic voice conversation agent",
    "author": "Dawayir Design Team",
    "lastUpdated": "2026-03-04"
  },

  "color": {
