        "950": { "$value": "#020208", "$type": "color" },
        "1000": { "$value": "#000000", "$type": "color" }
      }
    },

    "semantic": {
      "$description": "Purpose-driven color aliases",
      "brand": {
        "primary":   { "$value": "{color.primitive.cyan.500}", "$type": "color" },
        "secondary": { "$value": "{color.primitive.magenta.500}", "$type": "color" },
        "accent":    { "$value": "{color.primitive.gold.400}", "$type": "color" }
      },
      "background": {
        "deep":      { "$value": "{color.primitive.neutral.900}", "$type": "color" },
        "mid":       { "$value": "{color.primitive.neutral.800}", "$type": "color" },
        "surface":   { "$value": "rgba(8, 8, 28, 0.82)", "$type": "color" },
        "elevated":  { "$value": "rgba(255, 255, 255, 0.04)", "$type": "color" },
        "hover":     { "$value": "rgba(0, 245, 255, 0.08)", "$type": "color" },
        "active":    { "$value": "rgba(0, 245, 255, 0.15)", "$type": "color" },
        "overlay":   { "$value": "rgba(0, 0, 0, 0.5)", "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.primitive.neutral.50}", "$type": "color" },
        "secondary": { "$value": "rgba(200, 210, 240, 0.55)", "$type": "color" },
        "disabled":  { "$value": "rgba(200, 210, 240, 0.3)", "$type": "color" },
        "inverse":   { "$value": "#030814", "$type": "color" },
        "link":      { "$value": "{color.primitive.cyan.500}", "$type": "color" }
      },
      "border": {
        "default":   { "$value": "rgba(0, 245, 255, 0.12)", "$type": "color" },
        "hover":     { "$value": "rgba(0, 245, 255, 0.3)", "$type": "color" },
        "focus":     { "$value": "{color.primitive.cyan.500}", "$type": "color" },
        "subtle":    { "$value": "rgba(255, 255, 255, 0.06)", "$type": "color" },
        "strong":    { "$value": "rgba(255, 255, 255, 0.15)", "$type": "color" }
      },
      "status": {
        "success":   { "$value": "{color.primitive.green.500}", "$type": "color" },
        "warning":   { "$value": "{color.primitive.gold.400}", "$type": "color" },
        "error":     { "$value": "{color.primitive.red.500}", "$type": "color" },
        "info":      { "$value": "{color.primitive.cyan.500}", "$type": "color" }
      },
      "status-bg": {
        "success":   { "$value": "rgba(0, 255, 148, 0.07)", "$type": "color" },
        "warning":   { "$value": "rgba(255, 209, 102, 0.07)", "$type": "color" },
        "error":     { "$value": "rgba(255, 95, 109, 0.07)", "$type": "color" },
        "info":      { "$value": "rgba(0, 245, 255, 0.07)", "$type": "color" }
      },
      "status-border": {
        "success":   { "$value": "rgba(0, 255, 148, 0.25)", "$type": "color" },
        "warning":   { "$value": "rgba(255, 209, 102, 0.25)", "$type": "color" },
        "error":     { "$value": "rgba(255, 95, 109, 0.25)", "$type": "color" },
        "info":      { "$value": "rgba(0, 245, 255, 0.25)", "$type": "color" }
      }
    },

    "circle": {
      "$description": "Circle-specific semantic colors",
      "awareness": {
        "default":   { "$value": "#00F5FF", "$type": "color" },
        "glow":      { "$value": "rgba(0, 245, 255, 0.15)", "$type": "color" },
        "pulse":     { "$value": "rgba(0, 245, 255, 0.75)", "$type": "color" }
      },
      "knowledge": {
        "default":   { "$value": "#00FF41", "$type": "color" },
        "glow":      { "$value": "rgba(0, 255, 65, 0.15)", "$type": "color" },
        "pulse":     { "$value": "rgba(0, 255, 65, 0.75)", "$type": "color" }
      },
      "truth": {
        "default":   { "$value": "#FF00E5", "$type": "color" },
        "glow":      { "$value": "rgba(255, 0, 229, 0.15)", "$type": "color" },
        "pulse":     { "$value": "rgba(255, 0, 229, 0.75)", "$type": "color" }
      }
    },

    "emotion": {
      "$description": "Emotion-to-color mapping for Gemini bio-feedback",
      "calm":    { "$value": "#00CED1", "$type": "color" },
      "anxious": { "$value": "#FF6B35", "$type": "color" },
      "joyful":  { "$value": "#FFD700", "$type": "color" },
      "sad":     { "$value": "#4169E1", "$type": "color" },
      "stressed":{ "$value": "#ff5e5e", "$type": "color" }
    },

    "gradient": {
      "brand-text": {
        "$value": "linear-gradient(135deg, #ffffff 0%, #00f5ff 60%, #a0f0ff 100%)",
        "$type": "gradient"
      },
      "cta-primary": {
        "$value": "linear-gradient(90deg, #abfc55 0%, #20d866 100%)",
        "$type": "gradient"
      },
      "cta-hover": {
        "$value": "linear-gradient(90deg, #bfff70 0%, #28e674 100%)",
        "$type": "gradient"
      },
      "surface-glow": {
        "$value": "radial-gradient(ellipse at 30% 20%, rgba(0, 245, 255, 0.03) 0%, transparent 60%)",
        "$type": "gradient"
      }
    }
  },

  "typography": {
    "$description": "Typography tokens — 9-level type scale",

    "fontFamily": {
      "display":  { "$value": "'Outfit', sans-serif", "$type": "fontFamily", "$description": "Headings, brand, UI" },
      "body":     { "$value": "'Inter', sans-serif", "$type": "fontFamily", "$description": "Body text, secondary" },
      "arabic":   { "$value": "'Noto Kufi Arabic', 'Inter', sans-serif", "$type": "fontFamily", "$description": "Arabic text" },
      "mono":     { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily", "$description": "Code, technical" }
    },

    "fontWeight": {
      "light":     { "$value": 300, "$type": "fontWeight" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" },
      "black":     { "$value": 900, "$type": "fontWeight" }
    },

    "scale": {
      "$description": "9-level modular type scale (1.200 minor third ratio)",
      "nano": {
        "fontSize":   { "$value": "11px", "$type": "dimension" },
        "lineHeight": { "$value": "16px", "$type": "dimension" },
        "letterSpacing": { "$value": "0.4px", "$type": "dimension" },
        "$description": "Metric labels, tiny annotations"
      },
      "micro": {
        "fontSize":   { "$value": "10px", "$type": "dimension" },
        "lineHeight": { "$value": "14px", "$type": "dimension" },
        "letterSpacing": { "$value": "0.5px", "$type": "dimension" },
        "$description": "Footer info, smallest labels"
      },
      "caption": {
        "fontSize":   { "$value": "11px", "$type": "dimension" },
        "lineHeight": { "$value": "16px", "$type": "dimension" },
        "letterSpacing": { "$value": "0.3px", "$type": "dimension" },
        "$description": "Timestamps, report dates, preview headings"
      },
      "small": {
        "fontSize":   { "$value": "12px", "$type": "dimension" },
        "lineHeight": { "$value": "18px", "$type": "dimension" },
        "letterSpacing": { "$value": "0.2px", "$type": "dimension" },
        "$description": "Status badges, section labels"
      },
      "body": {
        "fontSize":   { "$value": "14px", "$type": "dimension" },
        "lineHeight": { "$value": "22px", "$type": "dimension" },
        "letterSpacing": { "$value": "0px", "$type": "dimension" },
        "$description": "Default body text, buttons"
      },
      "lead": {
        "fontSize":   { "$value": "16px", "$type": "dimension" },
        "lineHeight": { "$value": "24px", "$type": "dimension" },
        "letterSpacing": { "$value": "-0.1px", "$type": "dimension" },
        "$description": "Primary button text, large body"
      },
      "title": {
        "fontSize":   { "$value": "20px", "$type": "dimension" },
        "lineHeight": { "$value": "28px", "$type": "dimension" },
        "letterSpacing": { "$value": "-0.3px", "$type": "dimension" },
        "$description": "Section headers, dashboard titles"
      },
      "heading": {
        "fontSize":   { "$value": "26px", "$type": "dimension" },
        "lineHeight": { "$value": "34px", "$type": "dimension" },
        "letterSpacing": { "$value": "-0.5px", "$type": "dimension" },
        "$description": "Brand name, major headings"
      },
      "display": {
        "fontSize":   { "$value": "36px", "$type": "dimension" },
        "lineHeight": { "$value": "44px", "$type": "dimension" },
        "letterSpacing": { "$value": "-0.8px", "$type": "dimension" },
        "$description": "Hero text, splash screens"
      }
    },

    "responsive": {
      "$description": "Mobile overrides (max-width: 480px)",
      "heading": {
        "fontSize": { "$value": "22px", "$type": "dimension" }
      },
      "display": {
        "fontSize": { "$value": "28px", "$type": "dimension" }
      },
      "lead": {
        "fontSize": { "$value": "14px", "$type": "dimension" }
      }
    }
  },

  "spacing": {
    "$description": "8px-based spacing scale",
    "0":   { "$value": "0px", "$type": "dimension" },
    "1":   { "$value": "4px", "$type": "dimension", "$description": "Micro — icon gaps, thin dividers" },
    "2":   { "$value": "8px", "$type": "dimension", "$description": "Small — inner component spacing" },
    "3":   { "$value": "12px", "$type": "dimension", "$description": "Medium — standard gap, button padding" },
    "4":   { "$value": "16px", "$type": "dimension", "$description": "Default — section gaps, list spacing" },
    "5":   { "$value": "20px", "$type": "dimension", "$description": "Large — panel padding, mobile insets" },
    "6":   { "$value": "24px", "$type": "dimension", "$description": "XLarge — header margins, section breaks" },
    "7":   { "$value": "28px", "$type": "dimension", "$description": "Panel padding" },
    "8":   { "$value": "32px", "$type": "dimension", "$description": "XXLarge — overlay top padding" },
    "10":  { "$value": "40px", "$type": "dimension", "$description": "Major section separators" },
    "12":  { "$value": "48px", "$type": "dimension", "$description": "Page-level spacing" },
    "16":  { "$value": "64px", "$type": "dimension", "$description": "Hero spacing" },
    "20":  { "$value": "80px", "$type": "dimension", "$description": "Landmark spacing" }
  },

  "radius": {
    "$description": "Border radius tokens",
    "none":  { "$value": "0px", "$type": "dimension" },
    "xs":    { "$value": "4px", "$type": "dimension", "$description": "Bubble corners, tiny elements" },
    "sm":    { "$value": "8px", "$type": "dimension", "$description": "Tags, node labels" },
    "md":    { "$value": "12px", "$type": "dimension", "$description": "Small cards, icon buttons" },
    "lg":    { "$value": "16px", "$type": "dimension", "$description": "Standard buttons" },
    "xl":    { "$value": "20px", "$type": "dimension", "$description": "Transcript bubbles" },
    "2xl":   { "$value": "24px", "$type": "dimension", "$description": "Mobile overlay corners" },
    "3xl":   { "$value": "28px", "$type": "dimension", "$description": "Panel corners" },
    "full":  { "$value": "100px", "$type": "dimension", "$description": "Pill shapes, badges" },
    "circle":{ "$value": "50%", "$type": "dimension", "$description": "Circular elements" }
  },

  "shadow": {
    "$description": "Elevation and glow shadows",
    "none":  { "$value": "none", "$type": "shadow" },
    "sm":    { "$value": "0 2px 8px rgba(0, 0, 0, 0.3)", "$type": "shadow" },
    "md":    { "$value": "0 4px 20px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "lg":    { "$value": "0 8px 32px rgba(0, 0, 0, 0.5)", "$type": "shadow" },
    "xl":    { "$value": "0 24px 48px rgba(0, 0, 0, 0.7)", "$type": "shadow" },
    "panel": {
      "$value": "0 0 60px rgba(0, 245, 255, 0.04), 0 24px 48px rgba(0, 0, 0, 0.7)",
      "$type": "shadow",
      "$description": "Panel glow — combines cyan glow + heavy drop shadow"
    },
    "glow-cyan": {
      "$value": "0 0 20px rgba(0, 245, 255, 0.3)",
      "$type": "shadow"
    },
    "glow-cyan-strong": {
      "$value": "0 4px 20px rgba(0, 245, 255, 0.4)",
      "$type": "shadow"
    },
    "glow-green": {
      "$value": "0 0 10px rgba(0, 255, 148, 0.3)",
      "$type": "shadow"
    },
    "glow-red": {
      "$value": "0 0 10px rgba(255, 95, 109, 0.3)",
      "$type": "shadow"
    },
    "inset-dark": {
      "$value": "inset 0 0 20px rgba(0, 0, 0, 0.5)",
      "$type": "shadow"
    }
  },

  "blur": {
    "$description": "Backdrop blur tokens",
    "sm":    { "$value": "8px", "$type": "dimension" },
    "md":    { "$value": "10px", "$type": "dimension" },
    "lg":    { "$value": "16px", "$type": "dimension" },
    "xl":    { "$value": "28px", "$type": "dimension" }
  },

  "motion": {
    "$description": "Animation and transition tokens",
    "duration": {
      "instant":  { "$value": "0ms", "$type": "duration" },
      "fast":     { "$value": "120ms", "$type": "duration" },
      "normal":   { "$value": "200ms", "$type": "duration" },
      "moderate": { "$value": "300ms", "$type": "duration" },
      "slow":     { "$value": "400ms", "$type": "duration" },
      "slower":   { "$value": "600ms", "$type": "duration" },
      "deliberate": { "$value": "800ms", "$type": "duration" }
    },
    "easing": {
      "default":   { "$value": "ease", "$type": "cubicBezier" },
      "in":        { "$value": "ease-in", "$type": "cubicBezier" },
      "out":       { "$value": "ease-out", "$type": "cubicBezier" },
      "in-out":    { "$value": "ease-in-out", "$type": "cubicBezier" },
      "spring":    { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier", "$description": "Bouncy spring — primary CTA hover" },
      "smooth":    { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Material smooth" }
    }
  },

  "breakpoint": {
    "$description": "Responsive breakpoints",
    "xs":  { "$value": "320px", "$type": "dimension" },
    "sm":  { "$value": "480px", "$type": "dimension" },
    "md":  { "$value": "768px", "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  },

  "grid": {
    "$description": "12-column grid system",
    "columns":    { "$value": 12, "$type": "number" },
    "gutter":     { "$value": "16px", "$type": "dimension" },
    "margin": {
      "mobile":   { "$value": "16px", "$type": "dimension" },
      "tablet":   { "$value": "24px", "$type": "dimension" },
      "desktop":  { "$value": "32px", "$type": "dimension" }
    },
    "maxWidth":   { "$value": "1440px", "$type": "dimension" }
  },

  "zIndex": {
    "$description": "Z-index layering system",
    "base":       { "$value": 0, "$type": "number" },
    "raised":     { "$value": 1, "$type": "number" },
    "dropdown":   { "$value": 10, "$type": "number" },
    "sticky":     { "$value": 20, "$type": "number" },
    "overlay":    { "$value": 30, "$type": "number" },
    "modal":      { "$value": 40, "$type": "number" },
    "popover":    { "$value": 50, "$type": "number" },
    "toast":      { "$value": 60, "$type": "number" },
    "tooltip":    { "$value": 70, "$type": "number" },
    "max":        { "$value": 9999, "$type": "number" }
  },

  "opacity": {
    "0":    { "$value": 0, "$type": "number" },
    "5":    { "$value": 0.05, "$type": "number" },
    "10":   { "$value": 0.1, "$type": "number" },
    "20":   { "$value": 0.2, "$type": "number" },
    "30":   { "$value": 0.3, "$type": "number" },
    "40":   { "$value": 0.4, "$type": "number" },
    "50":   { "$value": 0.5, "$type": "number" },
    "60":   { "$value": 0.6, "$type": "number" },
    "70":   { "$value": 0.7, "$type": "number" },
    "80":   { "$value": 0.8, "$type": "number" },
    "90":   { "$value": 0.9, "$type": "number" },
    "100":  { "$value": 1, "$type": "number" }
  }
}
