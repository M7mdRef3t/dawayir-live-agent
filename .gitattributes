# Normalize line endings for the whole repo
# Windows → LF on checkout/commit (prevents CRLF noise in diffs)
* text=auto eol=lf

# Force LF for these file types explicitly
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
*.ps1  text eol=lf

# Binary files — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  binary
*.mp3  binary
*.mp4  binary
*.webm binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.pdf  binary
