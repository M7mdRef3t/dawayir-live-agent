{
  "name": "dawayir-live-agent",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:server": "node --test server/*.test.js",
    "coverage": "npm run coverage:server && npm run coverage:client",
    "coverage:server": "c8 npm run test:server",
    "coverage:client": "npm run --prefix client test:coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  },
  "c8": {
    "all": true,
    "include": [
      "server/**/*.js"
    ],
    "exclude": [
      "server/**/*.test.js",
      "server/node_modules/**"
    ],
    "reporter": [
      "text",
      "html"
    ]
  }
}